<div>
  <dt><%= Crm::Contact.human_attribute_name(:name) %></dt>
  <dd><%= @contact.name %></dd>
</div>
<div>
  <dt><%= Crm::Contact.human_attribute_name(:identity) %></dt>
  <dd><%= @contact.identity %></dd>
</div>
<div>
  <dt><%= Crm::Contact.human_attribute_name(:client_user_id) %></dt>
  <dd><%= @contact.client_user_id %></dd>
</div>

<% if defined? RailsWechat %>
  <div>
    <dt><%= Crm::Contact.human_attribute_name(:unionid) %></dt>
    <dd><%= @contact.unionid %></dd>
  </div>
<% end %>

<% if @scene&.qrcode_data_url && false %>
  <div>
    <dt></dt>
    <dd><%= image_tag @scene.qrcode_data_url, class: 'image is-128x128' %></dd>
  </div>
<% end %>

<% unless @contact.client_user %>
<div>
  <dt>绑定二维码</dt>
  <dd><%= image_tag @contact.qrcode_bind_url, class: 'image is-128x128' %></dd>
</div>
<% end %>
