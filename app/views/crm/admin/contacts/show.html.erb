<%= render 'contact_bar' %>

<div class="cards is-4">
  <div class="card">
    <div class="card-content text-centered">
      <strong><%= @contact.orders_count %></strong>
      <p><%= Crm::Contact.human_attribute_name(:orders_count) %></p>
    </div>
  </div>
  <div class="card">
    <div class="card-content text-centered">
      <strong><%= @contact.pending_members.count %></strong>
      <p>Contacts Count</p>
    </div>
  </div>
  <div class="card">
    <div class="card-content text-centered">
      <strong><%= @contact.wallets_count %></strong>
      <p><%= Crm::Contact.human_attribute_name(:wallets_count) %></p>
    </div>
  </div>
</div>

<dl class="as-show as-boxed">
  <%= render 'show_table' %>
</dl>
